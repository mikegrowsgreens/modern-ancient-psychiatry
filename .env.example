# Copy to .env.local and fill in. Never commit .env.local.

# --- Database ---
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# --- Auth ---
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# --- External APIs ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- n8n ---
# N8N_WEBHOOK_URL=

# --- Dagster GTM (if applicable) ---
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
